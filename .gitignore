# =====================================================

# .gitignore for .NET / Visual Studio Project

# PesoPinoy Microfinance System

# =====================================================

# ================================

# Build folders

# ================================

bin/
obj/
out/
build/
bld/
Debug/
Release/
x64/
x86/

# ================================

# Visual Studio files

# ================================

.vs/
.vscode/
*.suo
*.user
*.userosscache
*.sln.docstates
*.rsuser

# ================================

# Logs

# ================================

*.log
*.tlog

# ================================

# Temporary files

# ================================

*.tmp
*.temp
*.cache
*.bak
*.backup
*.old

# ================================

# Test Results

# ================================

TestResults/
*.trx
*.coverage
*.coveragexml

# ================================

# NuGet

# ================================

packages/
*.nupkg
*.nuget.props
*.nuget.targets

# ================================

# Node.js (if used)

# ================================

node_modules/
npm-debug.log
yarn-error.log
package-lock.json
yarn.lock

# ================================

# SQLite / Local Databases

# ================================

*.db
*.db-shm
*.db-wal
*.sqlite
*.sqlite3

# ================================

# Application settings

# ================================

appsettings.Development.json
appsettings.Local.json
appsettings.Production.json

# ================================

# Publish outputs

# ================================

publish/
*.publish.xml
*.publish.config

# ================================

# OS generated files

# ================================

Thumbs.db
ehthumbs.db
Desktop.ini
.DS_Store
$RECYCLE.BIN/

# ================================

# Backup files

# ================================

*.backup.json
backup_*.json

# ================================

# Keep important files

# ================================

!.gitkeep
!README.md
!.env.example
!appsettings.json
