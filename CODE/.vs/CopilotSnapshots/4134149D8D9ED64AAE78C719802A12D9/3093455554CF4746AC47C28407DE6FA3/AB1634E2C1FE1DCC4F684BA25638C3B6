        private async Task LoadBorrowersAsync()
        {
            try
            {
                var borrowers = await _borrowerService.GetAllBorrowersAsync();
                var activeBorrowers = borrowers.Where(b => b.IsActive).ToList();

                cmbBorrower.DisplayMember = "FullName";
                cmbBorrower.ValueMember = "BorrowerId";
                cmbBorrower.DataSource = activeBorrowers.Select(b => new
                {
                    BorrowerId = b.BorrowerId,
                    FullName = $"{b.LastName}, {b.FirstName}"
                }).ToList();

                if (!activeBorrowers.Any())
                {
                    lblStatus.Text = "No active borrowers found. Please add borrowers first.";
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Error loading borrowers: {ex.Message}", "Error",
                    MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

        private async Task LoadLoansAsync()
        {
            try
            {
                var loans = await _loanService.GetAllLoansAsync();
                dgvLoans.Rows.Clear();

                foreach (var loan in loans)
                {
                    dgvLoans.Rows.Add(
                        loan.LoanId,
                        loan.LoanNumber,
                        $"{loan.Borrower?.LastName}, {loan.Borrower?.FirstName}",
                        loan.PrincipalAmount,
                        $"{loan.InterestRate:F2}%",
                        loan.MonthlyPayment,
                        loan.BalanceRemaining,
                        loan.Status.ToString()
                    );
                }

                int activeCount = loans.Count(l => l.Status == LoanStatus.Active);
                int pendingCount = loans.Count(l => l.Status == LoanStatus.Pending);

                lblStatus.Text = $"Total Loans: {loans.Count()} | Active: {activeCount} | Pending: {pendingCount}";
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Error loading loans: {ex.Message}", "Error",
                    MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

        private async void CalculateLoan(object? sender, EventArgs e)
        {
            try
            {
                if (!ValidateLoanInput()) return;

                decimal principal = decimal.Parse(txtPrincipal.Text);
                int term = int.Parse(txtTerm.Text);

                if (cmbBorrower.SelectedValue != null)
                {
                    int borrowerId = (int)cmbBorrower.SelectedValue;
                    var borrower = await _borrowerService.GetBorrowerByIdAsync(borrowerId);

                    // Calculate interest based on risk score
                    decimal interestRate = CalculateInterestRate(borrower?.RiskScore ?? 50);
                    txtInterestRate.Text = interestRate.ToString("F2");

                    // Calculate monthly payment
                    var calculator = new LoanCalculator();
                    var result = calculator.CalculateLoan(principal, interestRate, term);

                    txtMonthlyPayment.Text = result.MonthlyPayment.ToString("N2");
                    txtTotalInterest.Text = result.TotalInterest.ToString("N2");
                    calculatedMonthlyPayment = result.MonthlyPayment;
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Error calculating loan: {ex.Message}", "Error",
                    MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

        private decimal CalculateInterestRate(decimal riskScore)
        {
            if (riskScore <= 30) return 5.0m;
            if (riskScore <= 50) return 7.0m;
            if (riskScore <= 70) return 10.0m;
            return 15.0m;
        }

        private async Task ApplyForLoanAsync()
        {
            try
            {
                if (!ValidateLoanInput()) return;

                var loan = new Loan
                {
                    BorrowerId = (int)cmbBorrower.SelectedValue!,
                    PrincipalAmount = decimal.Parse(txtPrincipal.Text),
                    InterestRate = decimal.Parse(txtInterestRate.Text),
                    TermInMonths = int.Parse(txtTerm.Text),
                    FirstPaymentDate = dtpFirstPayment.Value,
                    MonthlyPayment = calculatedMonthlyPayment,
                    Status = LoanStatus.Pending,
                    ApplicationDate = DateTime.Now,
                    LoanNumber = GenerateLoanNumber(),
                    BalanceRemaining = decimal.Parse(txtPrincipal.Text)
                };

                await _loanService.ApplyForLoanAsync(loan);

                MessageBox.Show("Loan application submitted successfully!", "Success",
                    MessageBoxButtons.OK, MessageBoxIcon.Information);

                ClearForm();
                await LoadLoansAsync();
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Error applying for loan: {ex.Message}", "Error",
                    MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

        private async Task ApproveLoanAsync()
        {
            try
            {
                if (selectedLoanId == 0)
                {
                    MessageBox.Show("Please select a loan to approve.", "Information",
                        MessageBoxButtons.OK, MessageBoxIcon.Information);
                    return;
                }

                var result = MessageBox.Show("Approve this loan?", "Confirm Approval",
                    MessageBoxButtons.YesNo, MessageBoxIcon.Question);

                if (result == DialogResult.Yes)
                {
                    await _loanService.ApproveLoanAsync(selectedLoanId);

                    MessageBox.Show("Loan approved successfully!", "Success",
                        MessageBoxButtons.OK, MessageBoxIcon.Information);

                    await LoadLoansAsync();
                    selectedLoanId = 0;
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Error approving loan: {ex.Message}", "Error",
                    MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

        private void ViewAmortizationSchedule(object? sender, EventArgs e)
        {
            if (selectedLoanId == 0)
            {
                MessageBox.Show("Please select a loan first.", "Information",
                    MessageBoxButtons.OK, MessageBoxIcon.Information);
                return;
            }

            var scheduleForm = new frmAmortizationSchedule(selectedLoanId);
            scheduleForm.ShowDialog();
        }

        private string GenerateLoanNumber()
        {
            return $"LN-{DateTime.Now:yyyyMMdd}-{Guid.NewGuid().ToString().Substring(0, 8).ToUpper()}";
        }

        private bool ValidateLoanInput()
        {
            if (cmbBorrower.SelectedValue == null)
            {
                MessageBox.Show("Please select a borrower.", "Validation Error",
                    MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return false;
            }

            if (string.IsNullOrWhiteSpace(txtPrincipal.Text) || !decimal.TryParse(txtPrincipal.Text, out decimal principal) || principal <= 0)
            {
                MessageBox.Show("Please enter a valid principal amount.", "Validation Error",
                    MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return false;
            }

            if (string.IsNullOrWhiteSpace(txtTerm.Text) || !int.TryParse(txtTerm.Text, out int term) || term <= 0 || term > 60)
            {
                MessageBox.Show("Please enter a valid term (1-60 months).", "Validation Error",
                    MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return false;
            }

            return true;
        }

        private void ClearForm()
        {
            cmbBorrower.SelectedIndex = -1;
            txtPrincipal.Clear();
            txtTerm.Clear();
            txtInterestRate.Clear();
            txtMonthlyPayment.Clear();
            txtTotalInterest.Clear();
            dtpFirstPayment.Value = DateTime.Now.AddMonths(1);
            selectedLoanId = 0;
        }
