        private async Task LoadLoansAsync()
        {
            try
            {
                var loans = await _loanService.GetAllLoansAsync();
                var activeLoans = loans.Where(l => l.Status == LoanStatus.Active).ToList();

                if (activeLoans.Any())
                {
                    cmbLoan.DisplayMember = "LoanInfo";
                    cmbLoan.ValueMember = "LoanId";
                    cmbLoan.DataSource = activeLoans.Select(l => new
                    {
                        LoanId = l.LoanId,
                        LoanInfo = $"{l.LoanNumber} - {l.Borrower?.LastName}, {l.Borrower?.FirstName} - Balance: {l.BalanceRemaining:C2}"
                    }).ToList();

                    lblStatus.Text = $"Found {activeLoans.Count} active loan(s)";
                }
                else
                {
                    cmbLoan.DataSource = null;
                    lblStatus.Text = "No active loans found. Please create and approve loans first.";
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Error loading loans: {ex.Message}", "Error",
                    MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

        private async void CmbLoan_SelectedIndexChanged(object? sender, EventArgs e)
        {
            if (cmbLoan.SelectedValue != null && cmbLoan.SelectedValue is int loanId)
            {
                selectedLoanId = loanId;
                await LoadLoanDetailsAsync(loanId);
            }
        }

        private async Task LoadLoanDetailsAsync(int loanId)
        {
            try
            {
                var loan = await _loanService.GetLoanByIdAsync(loanId);
                if (loan != null)
                {
                    var nextPayment = loan.AmortizationSchedules?
                        .FirstOrDefault(s => s.Status == PaymentStatus.Pending);

                    if (nextPayment != null)
                    {
                        lblLoanInfo.Text = $"Loan: {loan.LoanNumber} | Balance: {loan.BalanceRemaining:C2} | " +
                            $"Next Due: {nextPayment.DueDate:MM/dd/yyyy} | Amount Due: {nextPayment.PaymentAmount:C2}";

                        // Calculate penalty if payment date is after due date
                        UpdatePenalty();
                    }
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Error loading loan details: {ex.Message}", "Error",
                    MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

        private void DtpPaymentDate_ValueChanged(object? sender, EventArgs e)
        {
            UpdatePenalty();
        }

        private async void UpdatePenalty()
        {
            if (selectedLoanId == 0) return;

            try
            {
                var loan = await _loanService.GetLoanByIdAsync(selectedLoanId);
                if (loan != null)
                {
                    var nextPayment = loan.AmortizationSchedules?
                        .FirstOrDefault(s => s.Status == PaymentStatus.Pending);

                    if (nextPayment != null)
                    {
                        if (dtpPaymentDate.Value > nextPayment.DueDate)
                        {
                            int daysLate = PenaltyCalculator.CalculateDaysLate(nextPayment.DueDate, dtpPaymentDate.Value);
                            decimal penalty = PenaltyCalculator.CalculatePenalty(nextPayment.PaymentAmount, daysLate);
                            txtPenalty.Text = penalty.ToString("N2");
                        }
                        else
                        {
                            txtPenalty.Text = "0.00";
                        }
                    }
                }
            }
            catch (Exception ex)
            {
                System.Diagnostics.Debug.WriteLine($"Error updating penalty: {ex.Message}");
            }
        }

        private async Task LoadPaymentsAsync()
        {
            try
            {
                var payments = await _paymentService.GetAllPaymentsAsync();
                dgvPayments.Rows.Clear();

                foreach (var payment in payments.Take(50))
                {
                    dgvPayments.Rows.Add(
                        payment.PaymentId,
                        payment.PaymentNumber,
                        $"{payment.Loan?.LoanNumber}",
                        payment.AmountPaid,
                        payment.PaymentDate.ToShortDateString(),
                        payment.Status.ToString()
                    );
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Error loading payments: {ex.Message}", "Error",
                    MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

        private async Task LoadOverdueAsync()
        {
            try
            {
                var overdueLoans = await _loanService.GetOverdueLoansAsync();
                dgvOverdue.Rows.Clear();

                foreach (var loan in overdueLoans)
                {
                    var overdueSchedule = loan.AmortizationSchedules?
                        .FirstOrDefault(s => s.Status == PaymentStatus.Pending && s.DueDate < DateTime.Now);

                    if (overdueSchedule != null)
                    {
                        int daysLate = PenaltyCalculator.CalculateDaysLate(overdueSchedule.DueDate, DateTime.Now);
                        decimal penalty = PenaltyCalculator.CalculatePenalty(overdueSchedule.PaymentAmount, daysLate);

                        dgvOverdue.Rows.Add(
                            loan.LoanId,
                            $"{loan.Borrower?.LastName}, {loan.Borrower?.FirstName}",
                            overdueSchedule.PaymentAmount,
                            overdueSchedule.DueDate.ToShortDateString(),
                            daysLate,
                            penalty,
                            PenaltyCalculator.GetPenaltyStatus(daysLate)
                        );
                    }
                }

                lblStatus.Text = $"Found {overdueLoans.Count()} overdue loan(s).";
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Error loading overdue payments: {ex.Message}", "Error",
                    MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

        private async Task RecordPaymentAsync()
        {
            try
            {
                if (selectedLoanId == 0)
                {
                    MessageBox.Show("Please select a loan.", "Validation Error",
                        MessageBoxButtons.OK, MessageBoxIcon.Warning);
                    return;
                }

                if (!decimal.TryParse(txtAmount.Text, out decimal amount) || amount <= 0)
                {
                    MessageBox.Show("Please enter a valid payment amount.", "Validation Error",
                        MessageBoxButtons.OK, MessageBoxIcon.Warning);
                    return;
                }

                var loan = await _loanService.GetLoanByIdAsync(selectedLoanId);
                var nextPayment = loan?.AmortizationSchedules?
                    .FirstOrDefault(s => s.Status == PaymentStatus.Pending);

                if (nextPayment == null)
                {
                    MessageBox.Show("No pending payments found for this loan.", "Error",
                        MessageBoxButtons.OK, MessageBoxIcon.Error);
                    return;
                }

                var payment = new Payment
                {
                    LoanId = selectedLoanId,
                    PaymentDate = dtpPaymentDate.Value,
                    DueDate = nextPayment.DueDate,
                    AmountDue = nextPayment.PaymentAmount,
                    AmountPaid = amount,
                    LatePenalty = decimal.Parse(txtPenalty.Text),
                    PaymentMethod = "Cash",
                    Remarks = "Regular payment"
                };

                await _paymentService.RecordPaymentAsync(payment);

                MessageBox.Show($"Payment recorded successfully!\nAmount: {amount:C2}\nPenalty: {txtPenalty.Text:C2}",
                    "Success", MessageBoxButtons.OK, MessageBoxIcon.Information);

                txtAmount.Clear();
                txtPenalty.Text = "0.00";
                await LoadInitialDataAsync();
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Error recording payment: {ex.Message}", "Error",
                    MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }
