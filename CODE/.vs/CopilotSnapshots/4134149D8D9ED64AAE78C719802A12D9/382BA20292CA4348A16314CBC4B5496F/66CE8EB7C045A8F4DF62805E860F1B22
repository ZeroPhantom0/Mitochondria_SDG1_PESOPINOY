        private async Task SubmitClaimAsync()
        {
            try
            {
                if (cmbClaimPolicy.SelectedValue == null)
                {
                    MessageBox.Show("Please select a policy.", "Validation Error",
                        MessageBoxButtons.OK, MessageBoxIcon.Warning);
                    return;
                }

                if (!decimal.TryParse(txtClaimAmount.Text, out decimal amount) || amount <= 0)
                {
                    MessageBox.Show("Please enter a valid claim amount.", "Validation Error",
                        MessageBoxButtons.OK, MessageBoxIcon.Warning);
                    return;
                }

                if (string.IsNullOrWhiteSpace(txtClaimReason.Text))
                {
                    MessageBox.Show("Please enter claim reason.", "Validation Error",
                        MessageBoxButtons.OK, MessageBoxIcon.Warning);
                    return;
                }

                var claim = new InsuranceClaim
                {
                    InsurancePolicyId = (int)cmbClaimPolicy.SelectedValue,
                    ClaimAmount = amount,
                    ClaimReason = txtClaimReason.Text,
                    IncidentDate = dtpIncidentDate.Value
                };

                await _insuranceService.FileClaimAsync(claim);

                MessageBox.Show("✓ Claim filed successfully! It will be reviewed by our team.",
                    "Success", MessageBoxButtons.OK, MessageBoxIcon.Information);

                claimForm.Close();

                // Refresh claims
                if (selectedPolicyId > 0)
                    await LoadClaimsAsync(selectedPolicyId);
                await LoadAllClaimsAsync();
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Error filing claim: {ex.Message}", "Error",
                    MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

