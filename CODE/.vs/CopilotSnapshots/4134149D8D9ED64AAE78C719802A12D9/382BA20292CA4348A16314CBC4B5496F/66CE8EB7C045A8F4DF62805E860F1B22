        private async Task LoadPoliciesAsync()
        {
            try
            {
                var policies = await _insuranceService.GetAllPoliciesAsync();
                dgvPolicies.Rows.Clear();

                foreach (var policy in policies)
                {
                    string statusDisplay = policy.Status.ToString();

                    // Custom display for PaidUp
                    if (policy.Status == InsurancePolicyStatus.PaidUp)
                        statusDisplay = "Fully Paid";

                    dgvPolicies.Rows.Add(
                        policy.InsurancePolicyId,
                        policy.PolicyNumber,
                        $"{policy.Borrower?.LastName}, {policy.Borrower?.FirstName}",
                        policy.PolicyType,
                        policy.CoverageAmount,
                        policy.PremiumAmount,
                        statusDisplay
                    );
                }

                lblStatus.Text = $"✓ Loaded {policies.Count()} insurance policies.";
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Error loading policies: {ex.Message}", "Error",
                    MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

        private async Task LoadAllClaimsAsync()
        {
            try
            {
                var claims = await _insuranceService.GetAllClaimsAsync();
                dgvClaims.Rows.Clear();

                foreach (var claim in claims)
                {
                    string borrowerName = "Unknown";
                    if (claim.InsurancePolicy?.Borrower != null)
                    {
                        borrowerName = $"{claim.InsurancePolicy.Borrower.LastName}, {claim.InsurancePolicy.Borrower.FirstName}";
                    }
                    else if (claim.InsurancePolicy != null)
                    {
                        borrowerName = $"Policy #{claim.InsurancePolicy.PolicyNumber}";
                    }

                    dgvClaims.Rows.Add(
                        claim.InsuranceClaimId,
                        claim.ClaimNumber,
                        borrowerName,
                        claim.ClaimAmount,
                        claim.FilingDate.ToShortDateString(),
                        claim.Status,
                        claim.ClaimReason
                    );
                }

                if (claims.Any())
                {
                    lblStatus.Text = $"✓ Loaded {claims.Count()} claims. Click a claim to select it.";
                }
                else
                {
                    lblStatus.Text = "No claims found. Click 'FILE NEW CLAIM' to create one.";
                }
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Error loading claims: {ex.Message}", "Error",
                    MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

