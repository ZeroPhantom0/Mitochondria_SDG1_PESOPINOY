        private async Task RecordPremiumPayment()
        {
            try
            {
                if (selectedPolicyId == 0)
                {
                    MessageBox.Show("Please select a policy first.", "Validation Error",
                        MessageBoxButtons.OK, MessageBoxIcon.Warning);
                    return;
                }

                if (!decimal.TryParse(txtPaymentAmount.Text, out decimal amount) || amount <= 0)
                {
                    MessageBox.Show("Please enter a valid payment amount.", "Validation Error",
                        MessageBoxButtons.OK, MessageBoxIcon.Warning);
                    return;
                }

                if (cmbPaymentMethod.SelectedItem == null)
                {
                    MessageBox.Show("Please select a payment method.", "Validation Error",
                        MessageBoxButtons.OK, MessageBoxIcon.Warning);
                    return;
                }

                var payment = await _insuranceService.RecordPremiumPayment(
                    selectedPolicyId,
                    amount,
                    cmbPaymentMethod.SelectedItem.ToString(),
                    txtReferenceNumber.Text
                );

                MessageBox.Show($"✓ Payment recorded successfully!\n\n" +
                    $"Amount: {amount:C2}\n" +
                    $"Status: {payment.PaymentStatus}\n" +
                    $"Due Date: {payment.DueDate:d}",
                    "Success", MessageBoxButtons.OK, MessageBoxIcon.Information);

                // Refresh data
                await LoadPaymentHistory(selectedPolicyId);
                await LoadPaymentSummary(selectedPolicyId);
                await LoadPoliciesAsync(); // Refresh policy list to update status

                // Clear input fields
                txtPaymentAmount.Text = "0.00";
                cmbPaymentMethod.SelectedIndex = -1;
                txtReferenceNumber.Clear();
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Error recording payment: {ex.Message}", "Error",
                    MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

        private async Task CreatePolicyAsync()
        {
            try
            {
                if (!ValidateForm()) return;

                var policy = new InsurancePolicy
                {
                    BorrowerId = (int)cmbBorrower.SelectedValue,
                    PolicyType = cmbPolicyType.SelectedItem.ToString(),
                    CoverageAmount = decimal.Parse(txtCoverage.Text),
                    PremiumAmount = decimal.Parse(txtPremium.Text),
                    StartDate = dtpStart.Value,
                    EndDate = dtpEnd.Value,
                    BeneficiaryName = txtBeneficiary.Text,
                    BeneficiaryRelation = txtBeneficiaryRelation.Text,
                    Status = InsurancePolicyStatus.Pending
                };

                await _insuranceService.CreatePolicyAsync(policy);

                MessageBox.Show("✓ Insurance policy created successfully!", "Success",
                    MessageBoxButtons.OK, MessageBoxIcon.Information);

                ClearForm();
                await LoadPoliciesAsync();
            }
            catch (Exception ex)
            {
                MessageBox.Show($"Error creating policy: {ex.Message}", "Error",
                    MessageBoxButtons.OK, MessageBoxIcon.Error);
            }
        }

        private bool ValidateForm()
        {
            if (cmbBorrower.SelectedValue == null)
            {
                MessageBox.Show("Please select a borrower.", "Validation Error",
                    MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return false;
            }

            if (cmbPolicyType.SelectedItem == null)
            {
                MessageBox.Show("Please select a policy type.", "Validation Error",
                    MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return false;
            }

            if (!decimal.TryParse(txtCoverage.Text, out decimal coverage) || coverage <= 0)
            {
                MessageBox.Show("Please enter a valid coverage amount.", "Validation Error",
                    MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return false;
            }

            if (!decimal.TryParse(txtPremium.Text, out decimal premium) || premium <= 0)
            {
                MessageBox.Show("Please enter a valid premium amount.", "Validation Error",
                    MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return false;
            }

            if (dtpEnd.Value <= dtpStart.Value)
            {
                MessageBox.Show("End date must be after start date.", "Validation Error",
                    MessageBoxButtons.OK, MessageBoxIcon.Warning);
                return false;
            }

            return true;
        }

        private void ClearForm()
        {
            cmbBorrower.SelectedIndex = -1;
            cmbPolicyType.SelectedIndex = -1;
            txtCoverage.Clear();
            txtPremium.Clear();
            dtpStart.Value = DateTime.Now;
            dtpEnd.Value = DateTime.Now.AddYears(1);
            txtBeneficiary.Clear();
            txtBeneficiaryRelation.Clear();
        }
    }
