        private void CreatePoliciesGrid()
        {
            dgvPolicies = new DataGridView
            {
                Location = new Point(10, 10),
                Size = new Size(590, 540),
                BackgroundColor = Color.White,
                BorderStyle = BorderStyle.None,
                RowHeadersVisible = false,
                AutoSizeColumnsMode = DataGridViewAutoSizeColumnsMode.Fill,
                SelectionMode = DataGridViewSelectionMode.FullRowSelect,
                MultiSelect = false,
                ReadOnly = true,
                AllowUserToAddRows = false,
                RowTemplate = { Height = 35 }
            };

            // Add columns
            dgvPolicies.Columns.Add("PolicyId", "ID");
            dgvPolicies.Columns.Add("PolicyNumber", "Policy #");
            dgvPolicies.Columns.Add("Borrower", "Borrower");
            dgvPolicies.Columns.Add("Type", "Type");
            dgvPolicies.Columns.Add("Coverage", "Coverage");
            dgvPolicies.Columns.Add("Premium", "Premium");
            dgvPolicies.Columns.Add("Status", "Status");

            // Column styling
            dgvPolicies.Columns["PolicyId"].Width = 40;
            dgvPolicies.Columns["PolicyNumber"].Width = 100;
            dgvPolicies.Columns["Coverage"].DefaultCellStyle.Format = "C2";
            dgvPolicies.Columns["Coverage"].DefaultCellStyle.FormatProvider = new CultureInfo("en-PH");
            dgvPolicies.Columns["Premium"].DefaultCellStyle.Format = "C2";
            dgvPolicies.Columns["Premium"].DefaultCellStyle.FormatProvider = new CultureInfo("en-PH");

            // Header styling
            dgvPolicies.EnableHeadersVisualStyles = false;
            dgvPolicies.ColumnHeadersDefaultCellStyle.BackColor = Color.FromArgb(2, 58, 128);
            dgvPolicies.ColumnHeadersDefaultCellStyle.ForeColor = Color.White;
            dgvPolicies.ColumnHeadersDefaultCellStyle.Font = new Font("Segoe UI", 10, FontStyle.Bold);
            dgvPolicies.ColumnHeadersHeight = 40;

            // Cell styling
            dgvPolicies.DefaultCellStyle.Font = new Font("Segoe UI", 9);
            dgvPolicies.DefaultCellStyle.SelectionBackColor = Color.FromArgb(230, 242, 255);
            dgvPolicies.DefaultCellStyle.SelectionForeColor = Color.FromArgb(2, 58, 128);
            dgvPolicies.DefaultCellStyle.Padding = new Padding(5);

            // Color coding for status
            dgvPolicies.CellFormatting += (s, e) =>
            {
                if (dgvPolicies.Columns[e.ColumnIndex].Name == "Status" && e.Value != null)
                {
                    string status = e.Value.ToString();
                    switch (status)
                    {
                        case "Active":
                            e.CellStyle.ForeColor = Color.Blue;
                            e.CellStyle.Font = new Font("Segoe UI", 9, FontStyle.Bold);
                            break;
                        case "PaidUp":
                            e.CellStyle.ForeColor = Color.Green;
                            e.CellStyle.Font = new Font("Segoe UI", 9, FontStyle.Bold);
                            e.Value = "Fully Paid";
                            break;
                        case "Pending":
                            e.CellStyle.ForeColor = Color.Orange;
                            e.CellStyle.Font = new Font("Segoe UI", 9, FontStyle.Bold);
                            break;
                        case "Lapsed":
                            e.CellStyle.ForeColor = Color.Red;
                            e.CellStyle.Font = new Font("Segoe UI", 9, FontStyle.Bold);
                            break;
                        case "Expired":
                            e.CellStyle.ForeColor = Color.Gray;
                            break;
                        case "Claimed":
                            e.CellStyle.ForeColor = Color.Purple;
                            e.CellStyle.Font = new Font("Segoe UI", 9, FontStyle.Bold);
                            break;
                    }
                }
            };

            dgvPolicies.CellClick += DgvPolicies_CellClick;
        }

        private void CreateClaimsGrid()
        {
            dgvClaims = new DataGridView
            {
                Location = new Point(10, 10),
                Size = new Size(590, 480),
                BackgroundColor = Color.White,
                BorderStyle = BorderStyle.None,
                RowHeadersVisible = false,
                AutoSizeColumnsMode = DataGridViewAutoSizeColumnsMode.Fill,
                SelectionMode = DataGridViewSelectionMode.FullRowSelect,
                MultiSelect = false,
                ReadOnly = true,
                AllowUserToAddRows = false,
                RowTemplate = { Height = 35 }
            };

            // Add columns with specific names
            dgvClaims.Columns.Add("ClaimId", "ID");
            dgvClaims.Columns.Add("ClaimNumber", "Claim #");
            dgvClaims.Columns.Add("Borrower", "Borrower");
            dgvClaims.Columns.Add("Amount", "Amount");
            dgvClaims.Columns.Add("Date", "Filed Date");
            dgvClaims.Columns.Add("Status", "Status");
            dgvClaims.Columns.Add("Reason", "Reason");

            // Make sure ClaimId column exists and is visible but narrow
            if (dgvClaims.Columns["ClaimId"] != null)
            {
                dgvClaims.Columns["ClaimId"].Width = 40;
                dgvClaims.Columns["ClaimId"].Visible = true;
            }

            // Header styling
            dgvClaims.EnableHeadersVisualStyles = false;
            dgvClaims.ColumnHeadersDefaultCellStyle.BackColor = Color.FromArgb(2, 58, 128);
            dgvClaims.ColumnHeadersDefaultCellStyle.ForeColor = Color.White;
            dgvClaims.ColumnHeadersDefaultCellStyle.Font = new Font("Segoe UI", 10, FontStyle.Bold);
            dgvClaims.ColumnHeadersHeight = 40;

            dgvClaims.Columns["Amount"].DefaultCellStyle.Format = "C2";
            dgvClaims.Columns["Amount"].DefaultCellStyle.FormatProvider = new CultureInfo("en-PH");

            // Color coding for claim status
            dgvClaims.CellFormatting += (s, e) =>
            {
                if (dgvClaims.Columns[e.ColumnIndex].Name == "Status" && e.Value != null)
                {
                    string status = e.Value.ToString();
                    switch (status)
                    {
                        case "Pending":
                            e.CellStyle.ForeColor = Color.Orange;
                            e.CellStyle.Font = new Font("Segoe UI", 9, FontStyle.Bold);
                            break;
                        case "Approved":
                            e.CellStyle.ForeColor = Color.Green;
                            e.CellStyle.Font = new Font("Segoe UI", 9, FontStyle.Bold);
                            break;
                        case "Rejected":
                            e.CellStyle.ForeColor = Color.Red;
                            break;
                        case "Paid":
                            e.CellStyle.ForeColor = Color.Blue;
                            e.CellStyle.Font = new Font("Segoe UI", 9, FontStyle.Bold);
                            break;
                    }
                }
            };

            // Add click event to show selection
            dgvClaims.CellClick += (s, e) =>
            {
                if (e.RowIndex >= 0)
                {
                    dgvClaims.Rows[e.RowIndex].Selected = true;

                    if (dgvClaims.Rows[e.RowIndex].Cells["ClaimId"].Value != null)
                    {
                        int claimId = Convert.ToInt32(dgvClaims.Rows[e.RowIndex].Cells["ClaimId"].Value);
                        lblStatus.Text = $"Selected Claim ID: {claimId}";
                    }
                }
            };

            // Add double-click support
            dgvClaims.CellDoubleClick += (s, e) =>
            {
                if (e.RowIndex >= 0 && dgvClaims.Rows[e.RowIndex].Cells["ClaimId"].Value != null)
                {
                    int claimId = Convert.ToInt32(dgvClaims.Rows[e.RowIndex].Cells["ClaimId"].Value);
                    ShowProcessClaimForm(claimId);
                }
            };

            // Instruction label
            Label lblInstruction = new Label
            {
                Text = "👇 Click on a claim above, then click PROCESS CLAIM (or double-click)",
                Location = new Point(10, 495),
                Size = new Size(590, 20),
                Font = new Font("Segoe UI", 9, FontStyle.Italic),
                ForeColor = Color.FromArgb(100, 100, 100),
                TextAlign = ContentAlignment.MiddleCenter
            };
            tabClaims.Controls.Add(lblInstruction);

            // Button panel
            Panel buttonPanel = new Panel
            {
                Location = new Point(10, 520),
                Size = new Size(590, 50),
                BackColor = Color.Transparent
            };

            Button btnFileClaim = new Button
            {
                Text = "FILE NEW CLAIM",
                Location = new Point(10, 10),
                Size = new Size(150, 35),
                BackColor = Color.FromArgb(52, 152, 219),
                ForeColor = Color.White,
                FlatStyle = FlatStyle.Flat,
                Font = new Font("Segoe UI", 10, FontStyle.Bold),
                Cursor = Cursors.Hand
            };
            btnFileClaim.FlatAppearance.BorderSize = 0;
            btnFileClaim.Click += (s, e) => ShowClaimForm();

            Button btnProcessClaim = new Button
            {
                Text = "PROCESS CLAIM",
                Location = new Point(170, 10),
                Size = new Size(150, 35),
                BackColor = Color.FromArgb(46, 204, 113),
                ForeColor = Color.White,
                FlatStyle = FlatStyle.Flat,
                Font = new Font("Segoe UI", 10, FontStyle.Bold),
                Cursor = Cursors.Hand
            };
            btnProcessClaim.FlatAppearance.BorderSize = 0;
            btnProcessClaim.Click += (s, e) =>
            {
                // Check if any row is selected
                if (dgvClaims.SelectedRows.Count > 0)
                {
                    DataGridViewRow selectedRow = dgvClaims.SelectedRows[0];

                    if (selectedRow.Cells["ClaimId"].Value != null)
                    {
                        int claimId = Convert.ToInt32(selectedRow.Cells["ClaimId"].Value);
                        ShowProcessClaimForm(claimId);
                    }
                    else
                    {
                        MessageBox.Show("Selected claim data is invalid.", "Error",
                            MessageBoxButtons.OK, MessageBoxIcon.Error);
                    }
                }
                else
                {
                    // Try to get the current cell's row if no row is selected
                    if (dgvClaims.CurrentRow != null && dgvClaims.CurrentRow.Cells["ClaimId"].Value != null)
                    {
                        int claimId = Convert.ToInt32(dgvClaims.CurrentRow.Cells["ClaimId"].Value);
                        ShowProcessClaimForm(claimId);
                    }
                    else
                    {
                        MessageBox.Show("Please select a claim to process.\n\n" +
                            "1. Click on any claim in the list above\n" +
                            "2. The row should highlight in blue\n" +
                            "3. Then click PROCESS CLAIM",
                            "No Claim Selected",
                            MessageBoxButtons.OK,
                            MessageBoxIcon.Information);
                    }
                }
            };

            Button btnRefreshClaims = new Button
            {
                Text = "REFRESH",
                Location = new Point(330, 10),
                Size = new Size(100, 35),
                BackColor = Color.FromArgb(155, 89, 182),
                ForeColor = Color.White,
                FlatStyle = FlatStyle.Flat,
                Font = new Font("Segoe UI", 10, FontStyle.Bold),
                Cursor = Cursors.Hand
            };
            btnRefreshClaims.FlatAppearance.BorderSize = 0;
            btnRefreshClaims.Click += async (s, e) => await LoadAllClaimsAsync();

            buttonPanel.Controls.AddRange(new Control[] { btnFileClaim, btnProcessClaim, btnRefreshClaims });
            tabClaims.Controls.Add(dgvClaims);
            tabClaims.Controls.Add(lblInstruction);
            tabClaims.Controls.Add(buttonPanel);
        }

